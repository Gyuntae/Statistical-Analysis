# rfPermute Significance Testing for ≥80% Features


cat("\n=== STEP 5C: Statistical Significance Testing with rfPermute (p < 0.05) ===\n\n")

# Only proceed if we have features appearing in ≥80% of folds
if(!is.null(mda_80plus) && nrow(mda_80plus) > 0) {
  
  cat(sprintf("Testing %d features that appear in ≥80%% of folds...\n\n", 
              nrow(mda_80plus)))
  
  # Load rfPermute library
  if(!require("rfPermute")) {
    cat("Installing rfPermute package...\n")
    install.packages("rfPermute")
    library(rfPermute)
  }
  
  # Get the list of features to test (from ≥80% analysis)
  features_to_test <- mda_80plus$Feature
  
  cat(sprintf("Features to test: %d\n", length(features_to_test)))
  cat("Running permutation test (this may take a few minutes)...\n\n")
  
  # Prepare full dataset with only these features
  # Use the filtered features (after initial filtering)
  test_features <- features_filtered[, features_to_test]
  
  # Apply same preprocessing as in cross-validation
  cat("Preprocessing data for permutation test...\n")
  test_features_log <- apply_log_transform(test_features)
  lod_values_full <- calculate_lod(test_features_log)
  test_features_imputed <- impute_with_lod(test_features_log, lod_values_full)
  
  # Remove any samples with remaining NAs
  complete_cases <- complete.cases(test_features_imputed)
  test_features_clean <- test_features_imputed[complete_cases, ]
  group_clean <- group[complete_cases]
  
  # Combine with group
  dat_permute <- cbind(Group = group_clean, test_features_clean)
  
  cat(sprintf("Final dataset: %d samples, %d features\n\n", 
              nrow(dat_permute), ncol(test_features_clean)))
  
  # Run rfPermute
  cat("Running Random Forest with permutation testing...\n")
  cat("(Using 1000 trees and 100 permutations)\n\n")
  
  set.seed(123)
  rfp <- tryCatch({
    rfPermute(
      Group ~ .,
      data = dat_permute,
      ntree = 1000,
      num.rep = 1000,  # Number of permutations
      importance = TRUE
    )
  }, error = function(e) {
    cat(paste0("Error in rfPermute: ", e$message, "\n"))
    return(NULL)
  })
  
  if(!is.null(rfp)) {
    # Extract importance with p-values
    imp <- rfPermute::importance(rfp, scale = FALSE)
    
    # Get p-values (they're in the columns ending with ".pval")
    pval_col <- grep("pval", colnames(imp), value = TRUE)[1]
    
    # Create results dataframe
    rfp_results <- data.frame(
      Feature = rownames(imp),
      MDA = imp[, 1],  # Mean Decrease Accuracy
      pvalue = imp[, pval_col],
      Significant = imp[, pval_col] < 0.05
    )
    
    # Sort by p-value
    rfp_results <- rfp_results[order(rfp_results$pvalue), ]
    
    # Identify statistically significant features
    significant_features <- rfp_results$Feature[rfp_results$Significant]
    
    cat("\n")
    cat(rep("=", 80), "\n", sep = "")
    cat("PERMUTATION TEST RESULTS\n")
    cat(rep("=", 80), "\n", sep = "")
    cat(sprintf("Total features tested: %d\n", nrow(rfp_results)))
    cat(sprintf("Statistically significant (p < 0.05): %d (%.1f%%)\n\n",
                length(significant_features),
                length(significant_features) / nrow(rfp_results) * 100))
    
    cat("Top 20 features by p-value:\n")
    cat(rep("-", 80), "\n", sep = "")
    cat(sprintf("%-4s %-50s %12s %8s %s\n", 
                "Rank", "Feature", "MDA", "p-value", "Sig"))
    cat(rep("-", 80), "\n", sep = "")
    
    top_n <- min(20, nrow(rfp_results))
    for(i in 1:top_n) {
      sig_symbol <- ifelse(rfp_results$Significant[i], "***", "")
      cat(sprintf("%-4d %-50s %12.2f %8.4f %s\n",
                  i,
                  rfp_results$Feature[i],
                  rfp_results$MDA[i],
                  rfp_results$pvalue[i],
                  sig_symbol))
    }
    cat("\n")
    
    if(length(significant_features) > 0) {
      cat("Statistically significant features (p < 0.05):\n")
      cat(rep("-", 80), "\n", sep = "")
      for(i in 1:length(significant_features)) {
        idx <- which(rfp_results$Feature == significant_features[i])
        cat(sprintf("%2d. %-50s p = %.4f, MDA = %.2f\n",
                    i,
                    significant_features[i],
                    rfp_results$pvalue[idx],
                    rfp_results$MDA[idx]))
      }
      cat("\n")
    } else {
      cat("  WARNING: No features reached statistical significance (p < 0.05)\n\n")
    }
    
    # Merge with MDA analysis to compare
    mda_with_pval <- merge(mda_80plus, rfp_results[, c("Feature", "pvalue", "Significant")],
                           by = "Feature", all.x = TRUE)
    mda_with_pval <- mda_with_pval[order(mda_with_pval$pvalue), ]
    
    # Save results
    rfp_results_file <- file.path(analysis_dir, "rfPermute_Significance_Test.csv")
    write.csv(rfp_results, rfp_results_file, row.names = FALSE)
    cat(paste0("Permutation test results saved: ", rfp_results_file, "\n"))
    
    mda_with_pval_file <- file.path(analysis_dir, "MDA_with_Significance.csv")
    write.csv(mda_with_pval, mda_with_pval_file, row.names = FALSE)
    cat(paste0("MDA with p-values saved: ", mda_with_pval_file, "\n\n"))
    
    # Create visualization
    sig_plot_file <- file.path(analysis_dir, "Feature_Significance_Plot.png")
    png(sig_plot_file, width = 10, height = 6, units = "in", res = 300)
    
    par(mar = c(5, 15, 4, 2))
    
    # Plot top 20 features
    top_20 <- head(rfp_results, 20)
    colors <- ifelse(top_20$Significant, "lightskyblue", "gray60")
    
    barplot(-log10(top_20$pvalue),
            horiz = TRUE,
            names.arg = top_20$Feature,
            las = 1,
            col = colors,
            xlab = "-log10(p-value)",
            main = "Feature Significance",
            cex.names = 2,   # feature names
            cex.axis = 2,   # axis ticks
            cex.lab  = 2,   # axis label
            cex.main = 2.3)   # title
    
    abline(v = -log10(0.05), col = "red", lty = 2, lwd = 2)
    text(-log10(0.05), 1, "p = 0.05", pos = 4, col = "red", cex = 1.0)
    
    # Add legend outside
    #legend("topright", inset = c(-0.03, 0),  # negative x inset moves it outside
           #legend = c("Significant (p < 0.05)", "Not Significant"),
           #fill = c("lightskyblue", "gray60"),
           #cex = 1.0,
           #xpd = NA)  # allows plotting outside plot region
    
    dev.off()
    
    cat(paste0("Significance plot saved: ", sig_plot_file, "\n\n"))
    
  } else {
    cat("⚠️  rfPermute failed - skipping significance testing.\n\n")
    rfp_results <- NULL
    significant_features <- NULL
  }
  
} else {
  cat("No features in ≥80% of folds - skipping rfPermute test.\n\n")
  rfp_results <- NULL
  significant_features <- NULL
}

