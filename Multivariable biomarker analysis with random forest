# Log10 Transformation with LOD Imputation


# Function to apply log10 transformation
apply_log_transform <- function(data) {
  # Check for zero or negative values
  zero_neg_count <- sum(data <= 0, na.rm = TRUE)
  if(zero_neg_count > 0) {
    cat(paste0("  Note: Found ", zero_neg_count, " zero or negative values.\n"))
    cat("  Adding small constant before log transformation.\n")
  }
  
  # Log10 transform (add small constant to avoid log(0))
  log_data <- log10(data + 1e-10)
  return(log_data)
}

# calculate LOD (Limit of Detection) for imputation
# LOD = minimum non-missing value / 5
calculate_lod <- function(train_data) {
  lod_values <- sapply(train_data, function(col) {
    non_missing <- col[!is.na(col)]
    if(length(non_missing) > 0) {
      return(min(non_missing, na.rm = TRUE) / 5)
    } else {
      return(NA)
    }
  })
  return(lod_values)
}

# Function to impute missing values using LOD from training data
impute_with_lod <- function(data, lod_values) {
  data_imputed <- data
  for(col_name in names(lod_values)) {
    if(!is.na(lod_values[col_name])) {
      # Replace NA with LOD value
      data_imputed[[col_name]][is.na(data_imputed[[col_name]])] <- lod_values[col_name]
    }
  }
  return(data_imputed)
}


# Calculate Performance Metrics


calculate_performance <- function(predictions, true_labels, probabilities = NULL) {
  cm <- confusionMatrix(predictions, true_labels)
  accuracy <- cm$overall['Accuracy']
  
  # For binary classification
  if(length(levels(true_labels)) == 2) {
    sensitivity <- cm$byClass['Sensitivity']
    specificity <- cm$byClass['Specificity']
    precision <- cm$byClass['Pos Pred Value']
    f1 <- cm$byClass['F1']
    
    # Calculate AUC if probabilities provided
    if(!is.null(probabilities)) {
      roc_obj <- roc(as.numeric(true_labels), probabilities[, 2], quiet = TRUE)
      auc_value <- auc(roc_obj)
    } else {
      auc_value <- NA
    }
    
    return(list(
      Accuracy = accuracy,
      Sensitivity = sensitivity,
      Specificity = specificity,
      Precision = precision,
      F1 = f1,
      AUC = auc_value
    ))
  } else {
    # Multi-class
    return(list(
      Accuracy = accuracy,
      Sensitivity = mean(cm$byClass[, 'Sensitivity'], na.rm = TRUE),
      Specificity = mean(cm$byClass[, 'Specificity'], na.rm = TRUE),
      Precision = mean(cm$byClass[, 'Pos Pred Value'], na.rm = TRUE),
      F1 = mean(cm$byClass[, 'F1'], na.rm = TRUE),
      AUC = NA
    ))
  }
}


# Initial Random Forest on Each Fold


cat("\n=== STEP 2: Running Initial Random Forest on Each Fold (No Data Leakage) ===\n\n")
cat(paste0("Total samples: ", nrow(features_filtered), "\n"))
cat(paste0("Total features: ", ncol(features_filtered), "\n\n"))

for(i in 1:n_folds) {
  cat(paste0("Processing Fold ", i, "/", n_folds, "...\n"))
  
  # Split data into training and testing BEFORE any transformation
  test_idx <- folds[[i]]
  train_idx <- setdiff(1:nrow(features_filtered), test_idx)
  
  train_features <- features_filtered[train_idx, ]
  test_features <- features_filtered[test_idx, ]
  train_group <- group[train_idx]
  test_group <- group[test_idx]
  
  cat(paste0("  Training samples: ", length(train_idx), 
             ", Test samples: ", length(test_idx), "\n"))
  
  
  # STEP 1: Log10 transform SEPARATELY for train and test
  cat("  Step 1: Applying log10 transformation...\n")
  train_features_log <- apply_log_transform(train_features)
  test_features_log <- apply_log_transform(test_features)
  
  # STEP 2: Calculate LOD from TRAINING data only
  cat("  Step 2: Calculating LOD from training data (min/5)...\n")
  lod_values <- calculate_lod(train_features_log)
  
  # STEP 3: Impute missing values using training LOD for both sets
  cat("  Step 3: Imputing missing values with LOD...\n")
  train_features_imputed <- impute_with_lod(train_features_log, lod_values)
  test_features_imputed <- impute_with_lod(test_features_log, lod_values)
  
  # Check for remaining missing values
  train_missing <- sum(is.na(train_features_imputed))
  test_missing <- sum(is.na(test_features_imputed))
  
  if(train_missing > 0 || test_missing > 0) {
    cat(paste0("  WARNING: ", train_missing, " missing values in train, ", 
               test_missing, " in test after imputation.\n"))
    cat("  Removing samples with remaining missing values...\n")
    
    # Remove rows with any remaining NAs
    complete_train <- complete.cases(train_features_imputed)
    complete_test <- complete.cases(test_features_imputed)
    
    train_features_imputed <- train_features_imputed[complete_train, ]
    train_group <- train_group[complete_train]
    test_features_imputed <- test_features_imputed[complete_test, ]
    test_group <- test_group[complete_test]
    
    cat(paste0("  After removal: Training samples: ", nrow(train_features_imputed), 
               ", Test samples: ", nrow(test_features_imputed), "\n"))
  }
  
  # Combine with group for modeling
  train_data <- cbind(Group = train_group, train_features_imputed)
  test_data <- cbind(Group = test_group, test_features_imputed)
  

  # Train Random Forest model

  
  cat("  Step 4: Training Random Forest model...\n")
  
  # Adjust parameters for sample size
  max_mtry <- min(sqrt(ncol(train_features_imputed)), ncol(train_features_imputed) - 1)
  mtry_val <- max(1, floor(max_mtry))
  ntree_val <- ifelse(nrow(train_data) < 50, 300, 500)
  
  # Train Random Forest model
  rf_model <- tryCatch({
    randomForest(
      Group ~ .,
      data = train_data,
      importance = TRUE,
      ntree = ntree_val,
      mtry = mtry_val,
      nodesize = max(1, floor(nrow(train_data) * 0.05))
    )
  }, error = function(e) {
    cat(paste0("  Error in Fold ", i, ": ", e$message, "\n"))
    return(NULL)
  })
  
  if(is.null(rf_model)) {
    cat("  Skipping this fold due to error.\n\n")
    next
  }
  
  # Store model with fold number as name
  fold_rf_models_initial[[as.character(i)]] <- rf_model
  

  #  Calculate Training and Test Performance to detect overfitting

  cat("  Step 5: Evaluating overfitting (Train vs Test performance)...\n")
  
  # Predict on TRAINING data
  train_predictions <- predict(rf_model, train_data, type = "response")
  train_probabilities <- NULL
  if(length(levels(group)) == 2) {
    train_probabilities <- predict(rf_model, train_data, type = "prob")
  }
  
  # Predict on TEST data
  test_predictions <- predict(rf_model, test_data, type = "response")
  test_probabilities <- NULL
  if(length(levels(group)) == 2) {
    test_probabilities <- predict(rf_model, test_data, type = "prob")
  }
  
  # Calculate performance metrics
  train_perf <- calculate_performance(train_predictions, train_data$Group, train_probabilities)
  test_perf <- calculate_performance(test_predictions, test_data$Group, test_probabilities)
  
  # Calculate overfitting gap
  accuracy_gap <- train_perf$Accuracy - test_perf$Accuracy
  
  # Store overfitting metrics
  overfitting_metrics <- data.frame(
    Fold = i,
    Train_Accuracy = train_perf$Accuracy,
    Test_Accuracy = test_perf$Accuracy,
    Accuracy_Gap = accuracy_gap,
    Train_Sensitivity = train_perf$Sensitivity,
    Test_Sensitivity = test_perf$Sensitivity,
    Train_Specificity = train_perf$Specificity,
    Test_Specificity = test_perf$Specificity,
    Train_AUC = train_perf$AUC,
    Test_AUC = test_perf$AUC
  )
  
  fold_overfitting_metrics[[as.character(i)]] <- overfitting_metrics
  
  # Interpret overfitting
  overfitting_status <- if(accuracy_gap > 0.15) {
    " HIGH OVERFITTING"
  } else if(accuracy_gap > 0.10) {
    " MODERATE OVERFITTING"
  } else if(accuracy_gap > 0.05) {
    " SLIGHT OVERFITTING"
  } else {
    " GOOD GENERALIZATION"
  }
  
  cat(paste0("  Train Accuracy: ", round(train_perf$Accuracy * 100, 2), "%\n"))
  cat(paste0("  Test Accuracy:  ", round(test_perf$Accuracy * 100, 2), "%\n"))
  cat(paste0("  Gap: ", round(accuracy_gap * 100, 2), "% - ", overfitting_status, "\n"))
  
  # Extract feature importance (EXPLICIT namespace to avoid rfPermute conflict)
  importance_scores <- randomForest::importance(rf_model, type = 1)
  
  importance_df <- data.frame(
    Feature = rownames(importance_scores),
    Importance = importance_scores[, 1]
  )
  

  importance_df <- importance_df[order(-importance_df$Importance), ]
  
  # Store full importance with fold number as name
  fold_importance[[as.character(i)]] <- importance_df
  
  # Get top 10 features for this fold
  top10 <- importance_df$Feature[1:min(10, nrow(importance_df))]
  fold_top10_features[[as.character(i)]] <- top10
  
  cat(paste0("  Top 10 features identified for Fold ", i, "\n\n"))
}

