# aggregate MDA scores across folds
aggregate_mda_scores <- function(feature_list, fold_importance_list) {
  mda_summary <- data.frame()
  
  for(feature in feature_list) {
    mda_scores <- c()
    
    # Collect MDA scores from each fold where feature appears
    for(fold_name in names(fold_importance_list)) {
      importance_df <- fold_importance_list[[fold_name]]
      if(feature %in% importance_df$Feature) {
        mda_score <- importance_df$Importance[importance_df$Feature == feature]
        mda_scores <- c(mda_scores, mda_score)
      }
    }
    
    if(length(mda_scores) > 0) {
      # Calculate statistics
      feature_summary <- data.frame(
        Feature = feature,
        Mean_MDA = mean(mda_scores),
        SD_MDA = sd(mda_scores),
        Min_MDA = min(mda_scores),
        Max_MDA = max(mda_scores),
        N_Folds = length(mda_scores),
        Percentage_Folds = round(length(mda_scores) / length(fold_importance_list) * 100, 1)
      )
      
      mda_summary <- rbind(mda_summary, feature_summary)
    }
  }
  
  # Sort by Mean_MDA descending
  mda_summary <- mda_summary[order(-mda_summary$Mean_MDA), ]
  
  return(mda_summary)
}

# Function to interpret MDA importance
interpret_mda <- function(mda_value) {
  if(mda_value > 20) {
    return(" High")
  } else if(mda_value >= 10) {
    return("High")
  } else if(mda_value >= 5) {
    return("oderate")
  } else {
    return("Low")
  }
}

